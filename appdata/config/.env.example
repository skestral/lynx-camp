# Copy this file to appdata/config/.env on the server and fill in private values there.
CAMPFINDER_APP_BASE_URL=http://localhost:8080
CAMPFINDER_MIN_POLL_INTERVAL_MINUTES=10

# Around a calculated release time, temporarily scan more often.
CAMPFINDER_RELEASE_SCAN_BEFORE_MINUTES=15
CAMPFINDER_RELEASE_SCAN_AFTER_MINUTES=60
CAMPFINDER_RELEASE_SCAN_INTERVAL_MINUTES=10

# API safety and notification noise controls.
CAMPFINDER_AVAILABILITY_CACHE_MINUTES=5
CAMPFINDER_API_REQUEST_DELAY_SECONDS=1
CAMPFINDER_RATE_LIMIT_BACKOFF_MINUTES=60
CAMPFINDER_MAX_NOTIFICATION_RESULTS=5

# Optional generic webhook. Discord webhooks work with the default {"content": "..."} payload.
CAMPFINDER_WEBHOOK_URL=

# Optional ntfy mobile push. Subscribe to this topic in the ntfy phone app.
CAMPFINDER_NTFY_SERVER=https://ntfy.sh
CAMPFINDER_NTFY_TOPIC=
CAMPFINDER_NTFY_TOKEN=
CAMPFINDER_NTFY_PRIORITY=high

# Optional SMTP email notifications.
CAMPFINDER_SMTP_HOST=
CAMPFINDER_SMTP_PORT=587
CAMPFINDER_SMTP_USERNAME=
CAMPFINDER_SMTP_PASSWORD=
CAMPFINDER_SMTP_FROM=
CAMPFINDER_SMTP_TO=

# Optional high-priority Cart Assist guardrail. You can set these here or configure
# them later from the dashboard, which stores values in appdata/campfinder.db.
# This build records guarded assist attempts. It does not submit payment or bypass
# Recreation.gov login/CAPTCHA challenges.
CAMPFINDER_CART_ASSIST_ENABLED=false
CAMPFINDER_CART_ASSIST_COOLDOWN_MINUTES=30
CAMPFINDER_CART_ASSIST_MAX_ATTEMPTS_PER_SCAN=1
CAMPFINDER_RECREATION_GOV_USERNAME=
CAMPFINDER_RECREATION_GOV_PASSWORD=
